# =============================================================================
# Servidor STAGING + SCRAPER — MedForge
# Este servidor corre los scrapers externos y sirve como entorno de pruebas.
# Copia este archivo a:
#   /ruta/medforge/.env             (legacy PHP)
#   /ruta/medforge/laravel-app/.env (Laravel)
# y completa los valores marcados con <...>
# =============================================================================

# ── Rol ──────────────────────────────────────────────────────────────────────
# Solo corre tareas de scraping externo (CIVE, IESS, IA).
# Las tareas de lógica de negocio las maneja el servidor de producción.
SERVER_ROLE=scraper

# ── Aplicación ───────────────────────────────────────────────────────────────
APP_NAME=MedForge-Staging
APP_ENV=staging
APP_KEY=<genera con: php artisan key:generate --show>
APP_DEBUG=true
APP_URL=https://<dominio-staging>
APP_TIMEZONE=America/Guayaquil

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ── Logs ─────────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Base de datos (MISMO servidor DB de producción) ───────────────────────────
# Los datos scrapeados van directo a la DB de producción.
DB_CONNECTION=mysql
DB_HOST=<IP-SERVIDOR-DB>
DB_PORT=3306
DB_DATABASE=medforge
DB_USERNAME=<usuario-db>
DB_PASSWORD=<password-db>
DB_CHARSET=utf8mb4

# Legacy PHP usa estas mismas variables
DB_NAME=medforge
DB_USER=<usuario-db>
DB_PASS=<password-db>
DB_HOST=<IP-SERVIDOR-DB>

# ── Sesiones y caché ─────────────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
AUTH_ACCEPT_LEGACY_SESSION=true
AUTH_WRITE_LEGACY_COMPAT_SESSION=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Correo (apagar en staging para no enviar mails reales) ───────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="staging@medforge.local"
MAIL_FROM_NAME="MedForge Staging"

# ── NAS imágenes ─────────────────────────────────────────────────────────────
# NAS_IMAGES_MOUNT=/mnt/nas-imagenes
# NAS_IMAGES_SSH_HOST=<nas-host>
# NAS_IMAGES_SSH_PORT=22
# NAS_IMAGES_SSH_USER=<user>
# NAS_IMAGES_SSH_PASS=<pass>
# NAS_IMAGES_BASE_PATH=/Imagenes

# ── APIs externas ────────────────────────────────────────────────────────────
OPENAI_API_KEY=<openai-key>
# Apunta a producción para que el scraper llame al API correcto
MEDFORGE_API_URL=https://<dominio-produccion>
WHATSAPP_WEBHOOK_VERIFY_TOKEN=<token>
WHATSAPP_GRAPH_TIMEOUT=15
CIVE_EXTENSION_SECRET_KEY=<key>
WHATSAPP_FLOWMAKER_EMBED_URL=http://localhost:8000

# ── WhatsApp: desactivado en staging (evitar envíos reales) ──────────────────
WHATSAPP_LARAVEL_ENABLED=false
WHATSAPP_LARAVEL_FALLBACK_TO_LEGACY=true
WHATSAPP_LARAVEL_UI_ENABLED=false
WHATSAPP_LARAVEL_WEBHOOK_ENABLED=false
WHATSAPP_LARAVEL_AUTOMATION_ENABLED=false
WHATSAPP_LARAVEL_AUTOMATION_DRY_RUN=true
WHATSAPP_LARAVEL_TRANSPORT_DRY_RUN=true

# ── Strangler cutover flags (igual que producción para probar) ────────────────
BILLING_V2_WRITES_ENABLED=1
DASHBOARD_V2_UI_ENABLED=1
DASHBOARD_V2_DATA_ENABLED=0
SOLICITUDES_V2_WRITES_ENABLED=1
SOLICITUDES_V2_READS_ENABLED=1
SOLICITUDES_V2_UI_ENABLED=1
CONSULTAS_V2_READS_ENABLED=1
CONSULTAS_V2_WRITES_ENABLED=1
CONSULTAS_V2_API_ENABLED=0
EXAMENES_V2_READS_ENABLED=0
EXAMENES_V2_WRITES_ENABLED=0
EXAMENES_V2_UI_ENABLED=0
DERIVACIONES_V2_UI_ENABLED=0
USUARIOS_V2_UI_ENABLED=0
ROLES_V2_UI_ENABLED=0
CIRUGIAS_V2_READS_ENABLED=0
CIRUGIAS_V2_WRITES_ENABLED=0
CIRUGIAS_V2_UI_ENABLED=0
REPORTING_V2_PROTOCOL_DATA_ENABLED=0
REPORTING_V2_IMAGENES_012A_DATA_ENABLED=0
REPORTING_V2_IMAGENES_012B_DATA_ENABLED=0
REPORTING_V2_COBERTURA_DATA_ENABLED=0
REPORTING_V2_CONSULTA_DATA_ENABLED=0
REPORTING_V2_POST_SURGERY_REST_DATA_ENABLED=0
