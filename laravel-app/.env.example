APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=America/Guayaquil

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=medforge
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# NAS imagenes: si NAS_IMAGES_MOUNT existe y apunta a un mount local, Laravel lo usa antes que SFTP.
# NAS_IMAGES_MOUNT=/mnt/nas-imagenes
# NAS_IMAGES_CACHE_DIR=/var/cache/medforge/nas
# NAS_IMAGES_LIST_CACHE_TTL=600
# NAS_IMAGES_CACHE_TTL=21600
# NAS_IMAGES_SSH_HOST=
# NAS_IMAGES_SSH_PORT=22
# NAS_IMAGES_SSH_USER=
# NAS_IMAGES_SSH_PASS=
# NAS_IMAGES_BASE_PATH=/Imagenes

# WhatsApp strangler flags
WHATSAPP_LARAVEL_ENABLED=false
WHATSAPP_LARAVEL_FALLBACK_TO_LEGACY=true
WHATSAPP_LARAVEL_COMPARE_WITH_LEGACY=true
WHATSAPP_LARAVEL_UI_ENABLED=false
WHATSAPP_LARAVEL_API_READ_ENABLED=false
WHATSAPP_LARAVEL_API_WRITE_ENABLED=false
WHATSAPP_LARAVEL_WEBHOOK_ENABLED=false
WHATSAPP_LARAVEL_HANDOFF_REQUEUE_SCHEDULED=false
WHATSAPP_LARAVEL_AUTOMATION_ENABLED=false
WHATSAPP_LARAVEL_AUTOMATION_COMPARE_WITH_LEGACY=true
WHATSAPP_LARAVEL_AUTOMATION_FALLBACK_TO_LEGACY=true
WHATSAPP_LARAVEL_AUTOMATION_DRY_RUN=true
WHATSAPP_LARAVEL_TRANSPORT_DRY_RUN=false
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_GRAPH_TIMEOUT=15
WHATSAPP_LEGACY_CHAT_PATH=/whatsapp/chat
WHATSAPP_LEGACY_TEMPLATES_PATH=/whatsapp/templates
WHATSAPP_LEGACY_DASHBOARD_PATH=/whatsapp/dashboard
WHATSAPP_LEGACY_FLOWMAKER_PATH=/whatsapp/flowmaker
WHATSAPP_LEGACY_API_CONVERSATIONS_PATH=/whatsapp/api/conversations

VITE_APP_NAME="${APP_NAME}"
