# URL base donde responde Laravel v2 (strangler o instancia directa).
BASE_URL="http://127.0.0.1:8081"

# Base path del modulo derivaciones en v2.
DERIVACIONES_BASE_PATH="/v2/derivaciones"

# Cookie de sesion autenticada del login legacy.
# Ejemplo: abrir DevTools en navegador y copiar el valor de PHPSESSID.
SID="REEMPLAZAR_CON_PHPSESSID"

# Opcionales: si no se definen, el script intenta inferirlos desde datatable.
FORM_ID=""
HC_NUMBER=""
DERIVACION_ID=""

# Opcional: carpeta temporal para outputs.
TMP_DIR="/tmp"
