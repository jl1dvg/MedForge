<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Laravel auth and migrated admin modules
    RewriteRule ^auth/(login|logout)$ v2_kernel.php [QSA,L]
    RewriteRule ^(usuarios|roles)(/.*)?$ v2_kernel.php [QSA,L]

    # Strangler bridge: /v2/* -> Laravel kernel (parallel app)
    RewriteRule ^v2(/.*)?$ v2_kernel.php [QSA,L]

    # No reescribir si el archivo o carpeta existe
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Redirigir todas las peticiones a index.php
    RewriteRule ^ index.php [QSA,L]
</IfModule>
