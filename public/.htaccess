<IfModule mod_headers.c>
    SetEnvIf Origin "^https://cive\.consulmed\.me$" CORS_ORIGIN=https://cive.consulmed.me
    SetEnvIf Origin "^https://asistentecive\.consulmed\.me$" CORS_ORIGIN=https://asistentecive.consulmed.me
    SetEnvIf Origin "^https://cive\.ddns\.net:8085$" CORS_ORIGIN=https://cive.ddns.net:8085
    SetEnvIf Origin "^http://192\.168\.1\.13:8085$" CORS_ORIGIN=http://192.168.1.13:8085

    Header always set Access-Control-Allow-Origin "%{CORS_ORIGIN}e" env=CORS_ORIGIN
    Header always set Access-Control-Allow-Methods "GET, POST, OPTIONS" env=CORS_ORIGIN
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization" env=CORS_ORIGIN
    Header always set Access-Control-Max-Age "86400" env=CORS_ORIGIN
    Header always set Vary "Origin"
</IfModule>

# Short-circuit OPTIONS preflight — Apache responds directly, no PHP
RewriteEngine On

# Preserve Authorization for Laravel routes handled by v2_kernel.php
RewriteCond %{HTTP:Authorization} .
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule .* - [R=204,L]

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Laravel auth and migrated admin modules
    RewriteRule ^auth/(login|logout)$ v2_kernel.php [QSA,L]
    RewriteRule ^(usuarios|roles)(/.*)?$ v2_kernel.php [QSA,L]

    # Strangler bridge: /v2/* -> Laravel kernel (parallel app)
    RewriteRule ^v2(/.*)?$ v2_kernel.php [QSA,L]

    # No reescribir si el archivo o carpeta existe
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Redirigir todas las peticiones a index.php
    RewriteRule ^ index.php [QSA,L]
</IfModule>
