OPENAI_API_KEY=
DB_HOST=
DB_NAME=
DB_USER=
DB_PASS=

# Flowmaker embed URL para entornos locales
WHATSAPP_FLOWMAKER_EMBED_URL=http://localhost:8000

# Strangler cutover Billing writes (legacy frontend -> Laravel /v2)
# 0 = legacy write endpoints, 1 = /v2 write endpoints
BILLING_V2_WRITES_ENABLED=1

# Strangler cutover Dashboard UI (legacy /dashboard -> /v2/dashboard)
# 0 = dashboard UI legacy, 1 = redirect to Laravel UI
DASHBOARD_V2_UI_ENABLED=1

# Strangler cutover Dashboard data (legacy UI -> Laravel /v2/dashboard/summary)
# 0 = datos dashboard desde consultas legacy, 1 = datos desde /v2 con fallback automático a legacy
DASHBOARD_V2_DATA_ENABLED=0

# Strangler cutover Reporting protocol data (legacy PDF builder -> Laravel /v2/reports/protocolo/data)
# 0 = data de protocolo desde legacy, 1 = data desde Laravel /v2 con fallback automático a legacy
REPORTING_V2_PROTOCOL_DATA_ENABLED=0

# Strangler cutover Reporting imagenes 012A data (legacy PDF builder -> Laravel /v2/reports/imagenes/012a/data)
# 0 = data 012A desde legacy, 1 = data desde Laravel /v2 con fallback automático a legacy
REPORTING_V2_IMAGENES_012A_DATA_ENABLED=0

# Strangler cutover Reporting imagenes 012B data (legacy PDF builder -> Laravel /v2/reports/imagenes/012b/data)
# 0 = data 012B desde legacy, 1 = data desde Laravel /v2 con fallback automático a legacy
REPORTING_V2_IMAGENES_012B_DATA_ENABLED=0

# Strangler cutover Reporting cobertura data (legacy PDF builder -> Laravel /v2/reports/cobertura/data)
# 0 = data cobertura desde legacy, 1 = data desde Laravel /v2 con fallback automático a legacy
REPORTING_V2_COBERTURA_DATA_ENABLED=0

# Strangler cutover Reporting consulta data (legacy PDF builder -> Laravel /v2/reports/consulta/data)
# 0 = data consulta desde legacy, 1 = data desde Laravel /v2 con fallback automático a legacy
REPORTING_V2_CONSULTA_DATA_ENABLED=0

# Strangler cutover Reporting post-surgery rest data (legacy PDF builder -> Laravel /v2/reports/cirugias/descanso/data)
# 0 = data certificado descanso desde legacy, 1 = data desde Laravel /v2 con fallback automático a legacy
REPORTING_V2_POST_SURGERY_REST_DATA_ENABLED=0

# Strangler cutover Solicitudes writes (legacy frontend -> Laravel /v2)
# 0 = write endpoints legacy, 1 = /v2 para endpoints write migrados
SOLICITUDES_V2_WRITES_ENABLED=1

# Strangler cutover Solicitudes reads (legacy frontend -> Laravel /v2)
# 0 = read endpoints legacy, 1 = /v2 para endpoints read migrados
SOLICITUDES_V2_READS_ENABLED=1

# Strangler cutover Solicitudes UI (legacy /solicitudes* -> Laravel /v2/solicitudes*)
# 0 = UI legacy, 1 = redirect UI a /v2 para solicitudes, dashboard y turnero
SOLICITUDES_V2_UI_ENABLED=1
